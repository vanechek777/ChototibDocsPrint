<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== ЦВЕТА (СВЕТЛАЯ ТЕМА) ===== -->
    <Color x:Key="SidebarColor">#1B2838</Color>
    <Color x:Key="SidebarHoverColor">#263849</Color>
    <Color x:Key="SidebarActiveColor">#0D47A1</Color>
    <Color x:Key="HeaderColor">#1B2838</Color>
    <Color x:Key="AccentColor">#2196F3</Color>
    <Color x:Key="WarningColor">#FFF3CD</Color>
    <Color x:Key="WarningTextColor">#856404</Color>
    <Color x:Key="CardBgColor">#F5F7FA</Color>
    <Color x:Key="AltRowColor">#EBF5FB</Color>
    <Color x:Key="TextPrimaryColor">#1B2838</Color>
    <Color x:Key="TextSecondaryColor">#78909C</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="DangerColor">#F44336</Color>
    <Color x:Key="PageBgColor">#FFFFFF</Color>
    <!-- Подложка под логотип (на всю ширину панели) -->
    <Color x:Key="SidebarLogoPlateColor">#EAF2FA</Color>

    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarLogoPlateBrush" Color="{StaticResource SidebarLogoPlateColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="AltRowBrush" Color="{StaticResource AltRowColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="PageBgBrush" Color="{StaticResource PageBgColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="White"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#B0BEC5"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="GridLineBrush" Color="#E0E0E0"/>
    <!-- Кнопки «вторичные» и «успех» (импорт и т.п.) -->
    <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#90A4AE"/>
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#78909C"/>
    <SolidColorBrush x:Key="SuccessButtonBrush" Color="#43A047"/>
    <SolidColorBrush x:Key="SuccessButtonHoverBrush" Color="#388E3C"/>
    <!-- Иконки и подписи плиток главной — тон боковой панели -->
    <SolidColorBrush x:Key="DashboardTileIconBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="DashboardTileCaptionBrush" Color="{StaticResource SidebarColor}"/>

    <DrawingImage x:Key="DashboardPrintIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Geometry="M26.8 43.9V4H95.2V43.9M26.8 95.2H15.4C12.377 95.2 9.477 93.999 7.339 91.861C5.201 89.723 4 86.824 4 83.8V55.3C4 52.277 5.201 49.377 7.339 47.239C9.477 45.101 12.377 43.9 15.4 43.9H106.6C109.623 43.9 112.523 45.101 114.661 47.239C116.799 49.377 118 52.277 118 55.3V83.8C118 86.824 116.799 89.723 114.661 91.861C112.523 93.999 109.623 95.2 106.6 95.2H95.2M26.8 72.4H95.2V118H26.8V72.4Z">
                <GeometryDrawing.Pen><Pen Brush="{StaticResource DashboardTileIconBrush}" Thickness="8" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
            </GeometryDrawing>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="DashboardGroupsIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Geometry="M8,2 L38,2 C41.3,2 44,4.7 44,8 L44,38 C44,41.3 41.3,44 38,44 L8,44 C4.7,44 2,41.3 2,38 L2,8 C2,4.7 4.7,2 8,2 Z">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource DashboardTileIconBrush}" Thickness="2.5"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource DashboardTileIconBrush}" Geometry="M9,9 L20,9 C21.1,9 22,9.9 22,11 L22,20 C22,21.1 21.1,22 20,22 L9,22 C7.9,22 7,21.1 7,20 L7,11 C7,9.9 7.9,9 9,9 Z"/>
                <GeometryDrawing Brush="{StaticResource DashboardTileIconBrush}" Geometry="M26,9 L37,9 C38.1,9 39,9.9 39,11 L39,20 C39,21.1 38.1,22 37,22 L26,22 C24.9,22 24,21.1 24,20 L24,11 C24,9.9 24.9,9 26,9 Z"/>
                <GeometryDrawing Brush="{StaticResource DashboardTileIconBrush}" Geometry="M9,24 L20,24 C21.1,24 22,24.9 22,26 L22,35 C22,36.1 21.1,37 20,37 L9,37 C7.9,37 7,36.1 7,35 L7,26 C7,24.9 7.9,24 9,24 Z"/>
                <GeometryDrawing Brush="{StaticResource DashboardTileIconBrush}" Geometry="M26,24 L37,24 C38.1,24 39,24.9 39,26 L39,35 C39,36.1 38.1,37 37,37 L26,37 C24.9,37 24,36.1 24,35 L24,26 C24,24.9 24.9,24 26,24 Z"/>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="DashboardStudentsIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{StaticResource DashboardTileIconBrush}" Geometry="M10.174 11.345C9.217 11.345 8.345 11.088 7.557 10.575C6.769 10.062 6.141 9.373 5.671 8.509C5.211 7.644 4.981 6.681 4.981 5.618C4.981 4.601 5.211 3.669 5.671 2.823C6.141 1.967 6.769 1.283 7.557 0.77C8.345 0.257 9.217 0 10.174 0C11.139 0 12.016 0.257 12.804 0.77C13.592 1.274 14.216 1.954 14.676 2.809C15.146 3.656 15.38 4.592 15.38 5.618C15.38 6.672 15.146 7.631 14.676 8.495C14.216 9.36 13.592 10.053 12.804 10.575C12.016 11.088 11.139 11.345 10.174 11.345ZM2.895 22.96C1.957 22.96 1.24 22.775 0.744 22.406C0.248 22.037 0 21.492 0 20.772C0 19.961 0.226 19.11 0.677 18.219C1.138 17.328 1.806 16.499 2.683 15.734C3.559 14.96 4.626 14.334 5.884 13.857C7.141 13.371 8.571 13.127 10.174 13.127C11.776 13.127 13.206 13.371 14.464 13.857C15.721 14.334 16.788 14.96 17.665 15.734C18.541 16.499 19.205 17.328 19.657 18.219C20.117 19.11 20.348 19.961 20.348 20.772C20.348 21.492 20.1 22.037 19.604 22.406C19.108 22.775 18.395 22.96 17.465 22.96H2.895ZM37.826 11.385C36.861 11.385 35.985 11.129 35.197 10.615C34.417 10.102 33.793 9.413 33.324 8.549C32.863 7.676 32.633 6.712 32.633 5.659C32.633 4.641 32.863 3.71 33.324 2.863C33.793 2.008 34.422 1.324 35.21 0.81C35.998 0.297 36.87 0.041 37.826 0.041C38.791 0.041 39.668 0.297 40.456 0.81C41.244 1.315 41.868 1.994 42.329 2.85C42.798 3.696 43.033 4.628 43.033 5.645C43.033 6.708 42.798 7.671 42.329 8.536C41.868 9.4 41.244 10.093 40.456 10.615C39.668 11.129 38.791 11.385 37.826 11.385ZM30.548 23C29.609 23 28.892 22.811 28.396 22.433C27.9 22.064 27.653 21.523 27.653 20.812C27.653 20.002 27.878 19.151 28.33 18.26C28.79 17.368 29.459 16.54 30.335 15.775C31.212 15 32.279 14.374 33.536 13.897C34.794 13.411 36.224 13.168 37.826 13.168C39.429 13.168 40.859 13.411 42.116 13.897C43.374 14.374 44.441 15 45.317 15.775C46.194 16.54 46.858 17.368 47.309 18.26C47.77 19.151 48 20.002 48 20.812C48 21.523 47.752 22.064 47.256 22.433C46.76 22.811 46.043 23 45.105 23H30.548Z"/>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ===== ТЕНЬ ДЛЯ КАРТОЧЕК ===== -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1B2838"/>

    <!-- ===== НАВИГАЦИЯ (Sidebar RadioButton) ===== -->
    <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Background="Transparent" Padding="6,12" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                   Width="26" Height="26" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock x:Name="Caption" Text="{TemplateBinding Content}" Foreground="#CFD8DC" FontSize="10"
                                       HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                            <Setter TargetName="Caption" Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== КНОПКА-ПЛИТКА (Dashboard): светлая карточка; иконки — цвет панели ===== -->
    <Style x:Key="DashboardTileButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource DashboardTileCaptionBrush}"/>
        <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="12" Padding="20,25" Effect="{StaticResource CardShadow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AltRowBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AltRowBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== КАРТОЧКА СТАТИСТИКИ ===== -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20,15"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ===== СТИЛЬ DATAGRID ===== -->
    <Style x:Key="StyledDataGrid" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource PageBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource PageBgBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource AltRowBrush}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="DGColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush" Value="#263849"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DGRow" TargetType="DataGridRow">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#BBDEFB"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#90CAF9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Строки таблицы оценок: заголовки курсов без конфликта с hover/выделением -->
    <Style x:Key="StudentGradesGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCourseHeader}" Value="True">
                <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCourseHeader}" Value="False"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#BBDEFB"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCourseHeader}" Value="False"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#90CAF9"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ===== ПОЛЕ ПОИСКА ===== -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinWidth" Value="200"/>
    </Style>

    <!-- ===== ЗАГОЛОВОК СТРАНИЦЫ ===== -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <!-- Отступ сверху: большой кегль не обрезается по ascender при ScrollViewer -->
        <Setter Property="Padding" Value="0,6,0,0"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <!-- ===== КНОПКА ФИЛЬТРА ===== -->
    <Style x:Key="FilterToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="15,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="15" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== КНОПКА ДЕЙСТВИЯ ===== -->
    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1976D2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#B0BEC5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#D32F2F"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Background" Value="{StaticResource SuccessButtonBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SuccessButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryButtonHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== СТИЛИ ДИАЛОГОВ ===== -->
    <Style x:Key="DialogLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,10,0,4"/>
    </Style>

    <Style x:Key="DialogInput" TargetType="TextBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="DialogCombo" TargetType="ComboBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

</ResourceDictionary>
