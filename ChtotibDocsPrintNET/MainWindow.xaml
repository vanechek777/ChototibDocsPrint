<Window x:Class="ChtotibDocsPrintNET.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ChtotibDocsPrintNET.ViewModels"
        xmlns:v="clr-namespace:ChtotibDocsPrintNET.Views"
        Title="ЧТОТиБ Печать" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen" MinWidth="1024" MinHeight="600" Background="{DynamicResource PageBgBrush}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><v:DashboardPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GroupsViewModel}"><v:GroupsPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GroupDetailViewModel}"><v:GroupDetailPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentsViewModel}"><v:StudentsPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentDetailViewModel}"><v:StudentDetailPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PrintViewModel}"><v:PrintPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminViewModel}"><v:AdminPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><v:SettingsPage/></DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel Margin="0,10,0,0">
                <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10,12" CornerRadius="0"
                        Background="{DynamicResource SidebarLogoPlateBrush}">
                    <Image x:Name="AppLogoImage" MaxWidth="84" MaxHeight="48"
                           Stretch="Uniform" HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <StackPanel>
                    <RadioButton Style="{StaticResource NavButton}" Content="Главная"
                                 Tag="{StaticResource MainIcon}" IsChecked="{Binding SelectedNavIndex, Converter={StaticResource NavConverter}, ConverterParameter=0}"
                                 GroupName="Nav" Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Группы"
                                 Tag="{StaticResource GroupsIcon}" IsChecked="{Binding SelectedNavIndex, Converter={StaticResource NavConverter}, ConverterParameter=1}"
                                 GroupName="Nav" Command="{Binding NavigateToCommand}" CommandParameter="Groups"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Студенты"
                                 Tag="{StaticResource StudentsIcon}" IsChecked="{Binding SelectedNavIndex, Converter={StaticResource NavConverter}, ConverterParameter=2}"
                                 GroupName="Nav" Command="{Binding NavigateToCommand}" CommandParameter="Students"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Печать&#x0a;документов"
                                 Tag="{StaticResource DocsIcon}" IsChecked="{Binding SelectedNavIndex, Converter={StaticResource NavConverter}, ConverterParameter=3}"
                                 GroupName="Nav" Command="{Binding NavigateToCommand}" CommandParameter="Print"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Админ&#x0a;панель"
                                 Tag="{StaticResource AdminIcon}" IsChecked="{Binding SelectedNavIndex, Converter={StaticResource NavConverter}, ConverterParameter=4}"
                                 GroupName="Nav" Command="{Binding NavigateToCommand}" CommandParameter="Admin"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Настройки"
                                 Tag="{StaticResource SettsIcon}" IsChecked="{Binding SelectedNavIndex, Converter={StaticResource NavConverter}, ConverterParameter=5}"
                                 GroupName="Nav" Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>
