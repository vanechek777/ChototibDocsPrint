<Window x:Class="ChtotibDocsPrintNET.Views.Dialogs.ImportPickFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" MinHeight="380" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Background="{DynamicResource PageBgBrush}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TbTitle" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>

        <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" CornerRadius="8"
                Padding="14,12" Margin="0,12,0,16" BorderBrush="#E0DDD6" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="TbDescription" TextWrapping="Wrap" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" LineHeight="20"/>
                <TextBlock Text="Пример таблицы в Excel (первая строка — заголовок):"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,12,0,6"/>
                <Border Background="#F5F3EE" CornerRadius="4" Padding="10,8">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="TbSample" FontFamily="Consolas" FontSize="11.5"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Файл для импорта" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbPath" IsReadOnly="True" Style="{StaticResource DialogInput}"
                         VerticalContentAlignment="Center" MinHeight="36"
                         ToolTip="Выберите файл Excel или CSV"/>
                <Button Grid.Column="1" Content="Выбрать файл…" Style="{StaticResource ActionButton}"
                        Click="Browse_Click" Padding="16,8" Margin="10,0,0,0" MinWidth="140"/>
            </Grid>
            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,6,0,0" TextWrapping="Wrap"
                       Text="Поддерживаются: .xlsx, .xls, .csv"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Padding="20,8" Margin="0,0,10,0" IsCancel="True"/>
            <Button x:Name="BtnImport" Content="Импортировать" Style="{StaticResource SuccessButton}"
                    Click="Import_Click" Padding="20,8" IsDefault="True" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
