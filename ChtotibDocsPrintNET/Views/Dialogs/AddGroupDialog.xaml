<Window x:Class="ChtotibDocsPrintNET.Views.Dialogs.AddGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить группу" Width="480" Height="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource PageBgBrush}">
    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новая группа" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,10">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogLabel}" Text="Наименование группы *"/>
                <TextBox x:Name="TbName" Style="{StaticResource DialogInput}"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Специальность *"/>
                <ComboBox x:Name="CbSpecialty" Style="{StaticResource DialogCombo}" DisplayMemberPath="Name"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Год набора *"/>
                <TextBox x:Name="TbYear" Style="{StaticResource DialogInput}"/>
                <TextBlock x:Name="TbCourseHint" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Корпус"/>
                <ComboBox x:Name="CbAddress" Style="{StaticResource DialogCombo}">
                    <ComboBoxItem Content="Бабушкина, 66" IsSelected="True"/>
                    <ComboBoxItem Content="Бабушкина, 2Б"/>
                </ComboBox>

                <CheckBox x:Name="ChkGraduating" Content="Выпускная группа" FontSize="13" Margin="0,12,0,0"
                          Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Padding="20,8" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Style="{StaticResource ActionButton}"
                    Click="Save_Click" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
