<Window x:Class="ChtotibDocsPrintNET.Views.Dialogs.AddSpecialtyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить специальность" Width="550" Height="360" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource PageBgBrush}">
    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Новая специальность" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
        <StackPanel Grid.Row="1" Margin="0,10,0,10">
            <TextBlock Style="{StaticResource DialogLabel}" Text="Код специальности *"/>
            <TextBox x:Name="TbCode" Style="{StaticResource DialogInput}"/>

            <TextBlock Style="{StaticResource DialogLabel}" Text="Наименование *"/>
            <TextBox x:Name="TbName" Style="{StaticResource DialogInput}"/>

            <TextBlock Style="{StaticResource DialogLabel}" Text="Сокращение *"/>
            <TextBox x:Name="TbShortName" Style="{StaticResource DialogInput}"/>

            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"
                       Text="Пример: 09.02.07 Информационные системы и программирование (ИСиП-2025-1п)"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Padding="20,8" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Style="{StaticResource ActionButton}" Click="Save_Click" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
