<Window x:Class="ChtotibDocsPrintNET.Views.Dialogs.AddCommissionMemberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить члена комиссии" Width="420" Height="300" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource PageBgBrush}">
    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Новый член комиссии" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
        <StackPanel Grid.Row="1" Margin="0,10,0,10">
            <TextBlock Style="{StaticResource DialogLabel}" Text="ФИО *"/>
            <TextBox x:Name="TbFullName" Style="{StaticResource DialogInput}"/>
            <TextBlock Style="{StaticResource DialogLabel}" Text="Должность"/>
            <TextBox x:Name="TbPosition" Style="{StaticResource DialogInput}"/>
            <TextBlock Style="{StaticResource DialogLabel}" Text="Роль"/>
            <ComboBox x:Name="CbRole" Style="{StaticResource DialogCombo}">
                <ComboBoxItem Content="Председатель" IsSelected="True"/>
                <ComboBoxItem Content="Заместитель"/>
                <ComboBoxItem Content="Член комиссии"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Padding="20,8" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Style="{StaticResource ActionButton}" Click="Save_Click" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
