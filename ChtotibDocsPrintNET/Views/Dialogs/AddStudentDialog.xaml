<Window x:Class="ChtotibDocsPrintNET.Views.Dialogs.AddStudentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить студента" Width="450" Height="480" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource PageBgBrush}">
    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новый студент" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,10">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogLabel}" Text="Фамилия *"/>
                <TextBox x:Name="TbLastName" Style="{StaticResource DialogInput}"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Имя *"/>
                <TextBox x:Name="TbFirstName" Style="{StaticResource DialogInput}"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Отчество"/>
                <TextBox x:Name="TbMiddleName" Style="{StaticResource DialogInput}"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Группа *"/>
                <ComboBox x:Name="CbGroup" Style="{StaticResource DialogCombo}" DisplayMemberPath="Name"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Дата рождения"/>
                <DatePicker x:Name="DpBirthDate" FontSize="13" Padding="4"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Padding="20,8" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Style="{StaticResource ActionButton}"
                    Click="Save_Click" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
