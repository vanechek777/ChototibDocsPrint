<Window x:Class="ChtotibDocsPrintNET.Views.Dialogs.OneCConnectionWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер подключения к 1С" Width="720" Height="620" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource PageBgBrush}">
    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Подключение к 1С" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,12">
            <StackPanel>
                <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                            <Run FontWeight="Bold">Способ 1 (рекомендуется для начала):</Run>
                            <LineBreak/>
                            В 1С сформируйте отчёт или выгрузку в Excel/CSV (группы, студенты, оценки) и импортируйте кнопками в «Настройки → Импорт данных».
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold">Способ 2:</Run>
                            OData — если в 1С включена публикация стандартного интерфейса OData (часто путь …/odata/standard.odata/).
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold">В 1С нужно:</Run>
                            «Администрирование» → «Публикация на веб-сервере» (или IIS), включить OData, указить пользователя с правами чтения справочников.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource DialogLabel}" Text="URL OData (база публикации)"/>
                <TextBox x:Name="TbODataUrl" Style="{StaticResource DialogInput}"
                         ToolTip="Пример: http://192.168.1.10/ut/odata/standard.odata/"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Пользователь 1С"/>
                <TextBox x:Name="TbUser" Style="{StaticResource DialogInput}"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Пароль"/>
                <PasswordBox x:Name="TbPassword" Padding="8,6" FontSize="13"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Сущность OData для пробной выборки"/>
                <TextBox x:Name="TbEntity" Style="{StaticResource DialogInput}"
                         ToolTip="Имя из $metadata, например Catalog_Студенты — зависит от конфигурации"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="BtnTest" Content="Проверить OData" Style="{StaticResource ActionButton}" Padding="14,7" Margin="0,0,8,0" Click="BtnTest_Click"/>
                    <Button x:Name="BtnSample" Content="Получить образец JSON" Style="{StaticResource SecondaryButton}" Padding="14,7" Click="BtnSample_Click"/>
                </StackPanel>

                <TextBlock x:Name="TbStatus" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource AccentBrush}"/>

                <TextBlock Style="{StaticResource DialogLabel}" Text="Ответ сервера (образец)" Margin="0,8,0,0"/>
                <TextBox x:Name="TbSample" Style="{StaticResource DialogInput}" MinHeight="120" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>

                <Separator Margin="0,16,0,12"/>
                <TextBlock Text="Быстрый импорт из файла" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Margin="0,6,0,8" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Откроются те же диалоги, что в настройках: специальности → группы → студенты → предметы."/>
                <WrapPanel>
                    <Button Content="Специальности" Style="{StaticResource SuccessButton}" Padding="12,6" Margin="0,0,8,8" Click="ImportSpecialties_Click"/>
                    <Button Content="Группы" Style="{StaticResource SuccessButton}" Padding="12,6" Margin="0,0,8,8" Click="ImportGroups_Click"/>
                    <Button Content="Студенты" Style="{StaticResource SuccessButton}" Padding="12,6" Margin="0,0,8,8" Click="ImportStudents_Click"/>
                    <Button Content="Предметы" Style="{StaticResource SuccessButton}" Padding="12,6" Margin="0,0,8,8" Click="ImportSubjects_Click"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить настройки" Style="{StaticResource ActionButton}" Padding="16,8" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Закрыть" Style="{StaticResource SecondaryButton}" Padding="16,8" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
