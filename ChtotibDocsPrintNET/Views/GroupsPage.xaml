<UserControl x:Class="ChtotibDocsPrintNET.Views.GroupsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{DynamicResource PageBgBrush}">
    <DockPanel Margin="30,20">
        <!-- Заголовок -->
        <TextBlock Text="Группы" Style="{StaticResource PageTitle}" DockPanel.Dock="Top"/>

        <!-- Панель фильтров -->
        <DockPanel DockPanel.Dock="Top" Margin="0,5,0,15">
            <!-- Левая часть: фильтры -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <CheckBox Content="Показать только выпускные" IsChecked="{Binding ShowOnlyGraduating}"
                          VerticalAlignment="Center" Margin="0,0,20,0" FontSize="13"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>

                <!-- Выбор корпуса -->
                <TextBlock Text="Корпус:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox ItemsSource="{Binding Addresses}" SelectedItem="{Binding SelectedAddress}"
                          Width="180" FontSize="13" Padding="8,5" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Правая часть: поиск + кнопка добавить -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Image Source="{StaticResource SearchIcon}" Width="18" Height="18" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Style="{StaticResource SearchBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                <Button Style="{StaticResource SuccessButton}" Content="↓ Импорт" FontSize="12" Padding="10,5"
                        Command="{Binding ImportGroupsCommand}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                <Button Style="{StaticResource ActionButton}" Content="+" FontSize="18" Padding="8,2"
                        Command="{Binding AddGroupCommand}" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- Статус -->
        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Всего групп: "/><Run Text="{Binding TotalGroupsCount, Mode=OneWay}"/>
        </TextBlock>

        <!-- Таблица групп -->
        <DataGrid Style="{StaticResource StyledDataGrid}" ItemsSource="{Binding Groups}"
                  ColumnHeaderStyle="{StaticResource DGColumnHeader}" RowStyle="{StaticResource DGRow}">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenGroupCommand}"
                              CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ п/п" Binding="{Binding Id}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Наименование группы" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Специальность" Binding="{Binding SpecialtyName}" Width="150"/>
                <DataGridTextColumn Header="Студентов" Binding="{Binding StudentCount}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
