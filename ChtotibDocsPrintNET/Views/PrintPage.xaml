<UserControl x:Class="ChtotibDocsPrintNET.Views.PrintPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:ChtotibDocsPrintNET.Converters"
             mc:Ignorable="d" Background="{DynamicResource PageBgBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:DiplomaRightGripCanvasLeftConverter x:Key="DiplomaRightGripCanvasLeftConverter"/>
        <conv:AppendixBottomGripCanvasLeftConverter x:Key="AppendixBottomGripCanvasLeftConverter"/>
        <conv:AppendixBottomGripCanvasTopConverter x:Key="AppendixBottomGripCanvasTopConverter"/>
        <conv:BlockCenterXConverter x:Key="BlockCenterXConverter"/>
        <conv:AppendixTableColumnWidthConverter x:Key="AppendixTableColumnWidthConverter"/>
        <conv:AppendixGradesTailColumnWidthMultiConverter x:Key="AppendixGradesTailColumnWidthMultiConverter"/>
        <conv:AppendixGradesSplitGripCanvasLeftMultiConverter x:Key="AppendixGradesSplitGripCanvasLeftMultiConverter"/>
        <conv:AppendixPracticeColumnWidthMultiConverter x:Key="AppendixPracticeColumnWidthMultiConverter"/>
        <conv:AppendixPracticeSplitGripCanvasLeftMultiConverter x:Key="AppendixPracticeSplitGripCanvasLeftMultiConverter"/>
        <Style x:Key="PreviewPanelExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="IsExpanded" Value="False"/>
        </Style>
        <conv:PreviewFitSizeConverter x:Key="PreviewFitSizeConverter"/>
        <!-- Подгонка: Uniform — весь лист виден в рамке. Кроп — четырьмя линейками на холсте. -->
        <Style x:Key="DiplomaPreviewViewboxStyle" TargetType="Viewbox">
            <Setter Property="Stretch" Value="None"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding FitPreviewToFrame}" Value="True">
                    <Setter Property="Stretch" Value="Uniform"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="MaxHeight" Value="{Binding ElementName=PreviewScrollViewer, Path=ActualHeight, Converter={StaticResource PreviewFitSizeConverter}, ConverterParameter=20}"/>
                    <Setter Property="MaxWidth" Value="{Binding ElementName=PreviewScrollViewer, Path=ActualWidth, Converter={StaticResource PreviewFitSizeConverter}, ConverterParameter=20}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="30,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== ЛЕВАЯ ПАНЕЛЬ ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="0" Margin="0,0,20,0">
            <StackPanel>
                <TextBlock Text="Печать документов" Style="{StaticResource PageTitle}"/>

                <TextBlock Text="Выберите группу:" FontSize="13" Margin="0,15,0,5"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <ComboBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}"
                          DisplayMemberPath="Name" FontSize="13" Padding="8,6"/>

                <TextBlock Text="Распечатать для:" FontSize="13" Margin="0,12,0,5"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <ComboBox ItemsSource="{Binding PrintTargets}" SelectedItem="{Binding PrintTarget}"
                          FontSize="13" Padding="8,6"/>

                <!-- Список студентов (чекбоксы) -->
                <StackPanel Visibility="{Binding ShowStudentsList, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,10,0,0">
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock Text="Студенты:" FontSize="13" FontWeight="SemiBold" DockPanel.Dock="Left"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Все" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"
                                    Command="{Binding SelectAllStudentsCommand}" Margin="0,0,4,0"/>
                            <Button Content="Нет" Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11"
                                    Command="{Binding DeselectAllStudentsCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Students}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="6,3" FontSize="12"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Command="{Binding DataContext.StudentSelectionChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <TextBlock><Run Text="{Binding LastName, Mode=OneWay}"/> <Run Text="{Binding FirstName, Mode=OneWay}"/> <Run Text="{Binding MiddleName, Mode=OneWay}"/></TextBlock>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <TextBlock Text="Тип документа:" FontSize="13" Margin="0,12,0,5" Foreground="{StaticResource TextPrimaryBrush}"/>
                <ComboBox ItemsSource="{Binding DocumentTypes}" SelectedItem="{Binding SelectedDocumentType}" FontSize="13" Padding="8,6"/>

                <TextBlock Text="Дата выдачи (по умолчанию):" FontSize="13" Margin="0,12,0,5" Foreground="{StaticResource TextPrimaryBrush}"/>
                <DatePicker SelectedDate="{Binding IssueDate}" FontSize="13" Padding="4"/>
                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="Для каждого студента можно задать свою дату в карточке (Дипломы.IssueDate). Если не задана — используется дата слева."/>

                <TextBlock Text="Председатель ГЭК:" FontSize="13" Margin="0,12,0,5" Foreground="{StaticResource TextPrimaryBrush}"/>
                <ComboBox ItemsSource="{Binding Chairmen}" SelectedItem="{Binding SelectedChairman}"
                          DisplayMemberPath="FullName" FontSize="13" Padding="8,6"/>

                <CheckBox Margin="0,14,0,0" Content="Печать подложки (бланк JPG)"
                          IsChecked="{Binding PrintDrawBackground, Mode=TwoWay}"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                <CheckBox Margin="0,6,0,0" Content="Печать дубликата (надпись «Дубликат»)"
                          IsChecked="{Binding PrintIsDuplicate, Mode=TwoWay}"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                <CheckBox Margin="0,6,0,0" Content="Печать заголовка «Квалификация» (оборот)"
                          IsChecked="{Binding PrintQualificationLabel, Mode=TwoWay}"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                          ToolTip="Включите, если на шаблоне нет готовой надписи «Квалификация». Шрифт Lazurski, цвет как на бланке."/>
                <Grid Margin="0,6,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PrintQualificationLabel}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="64"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                               Text="Кегль «Квалификация»"/>
                    <TextBox Grid.Column="1" Margin="8,0,0,0" Padding="6,4" FontSize="12"
                             ToolTip="Размер заголовка на обороте (8–48 px)."
                             Text="{Binding DiplomaBackOverlay.QualLabelFontSize, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"/>
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PrintIsDuplicate}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="64"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Кегль «Дубликат» (лицевая)"/>
                            <TextBox Grid.Column="1" Margin="8,0,0,0" Padding="6,4" FontSize="12"
                                     ToolTip="Размер на лицевой стороне (8–48)."
                                     Text="{Binding DiplomaFrontOverlay.DuplicateFontSize, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="64"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Кегль «Дубликат» (оборот)"/>
                            <TextBox Grid.Column="1" Margin="8,0,0,0" Padding="6,4" FontSize="12"
                                     ToolTip="Размер на оборотной стороне (8–48)."
                                     Text="{Binding DiplomaBackOverlay.DuplicateFontSize, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
                <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                           Text="Диплом с отличием: подложка и координаты надписей — отдельный профиль (красный бланк). Включается при всех итоговых «5» или типе «С отличием» в карточке. JPG — блок «Шаблоны» (DiplomaExcellent_Front/Back)."/>

                <Button Style="{StaticResource SecondaryButton}" Command="{Binding RefreshPreviewCommand}"
                        Padding="14,8" Margin="0,12,0,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Обновить предпросмотр" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="↻" FontSize="16" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,10" Margin="0,18,0,0">
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                        <Run Text="Документов: "/><Run Text="{Binding TotalDocuments, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text="  •  "/><Run Text="{Binding EstimatedSize, Mode=OneWay}"/>
                    </TextBlock>
                </Border>

                <Button Style="{StaticResource ActionButton}" Command="{Binding PrintToPrinterCommand}"
                        Padding="18,10" Margin="0,12,0,0" HorizontalAlignment="Stretch"
                        ToolTip="Сформировать документ и отправить на выбранный принтер">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Печать" FontSize="14" VerticalAlignment="Center"/>
                        <Image Source="{StaticResource PrintIconWhite}" Width="18" Height="18" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryButton}" Command="{Binding SaveToPdfCommand}"
                        Padding="18,10" Margin="0,8,0,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Сохранить в PDF" FontSize="14" VerticalAlignment="Center"/>
                        <Image Source="{StaticResource DownloadIcon}" Width="16" Height="16" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <StackPanel Margin="0,10,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPdfGenerating}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding PdfProgress, Mode=OneWay}"/>
                    <TextBlock Text="{Binding PdfProgressText}" Margin="0,6,0,0" FontSize="11"
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,15" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== ПРАВАЯ ПАНЕЛЬ: ПРЕДПРОСМОТР ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Предпросмотр" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ToggleButton Content="Подогнать" IsChecked="{Binding FitPreviewToFrame}"
                                  Padding="10,5" FontSize="12" Margin="0,0,10,0"
                                  Foreground="White" Background="{StaticResource SecondaryButtonBrush}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryButtonHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                            </ToggleButton.Template>
                    </ToggleButton>
                    <Button Content="−" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="14"
                            Command="{Binding ZoomOutCommand}" Margin="0,0,4,0"/>
                    <TextBlock Width="54" TextAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}">
                        <TextBlock.Text>
                            <Binding Path="PreviewZoom" StringFormat="{}{0:P0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <Button Content="+" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="14"
                            Command="{Binding ZoomInCommand}" Margin="0,0,10,0"/>
                    <Slider Width="140" Minimum="0.25" Maximum="5" Value="{Binding PreviewZoom}" SmallChange="0.05" LargeChange="0.1">
                        <Slider.Style>
                            <Style TargetType="Slider">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FitPreviewToFrame}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Slider.Style>
                    </Slider>
                    <Button Content="◀" Style="{StaticResource ActionButton}" Padding="10,5" FontSize="14"
                            Command="{Binding PrevPreviewStudentCommand}" Margin="10,0,4,0"/>
                    <Button Content="▶" Style="{StaticResource ActionButton}" Padding="10,5" FontSize="14"
                            Command="{Binding NextPreviewStudentCommand}"/>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*" MinHeight="120"/>
                    <RowDefinition Height="*" MinHeight="72"/>
                </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding PreviewStudentLabel}" FontSize="13" Margin="0,0,0,6"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <Border Grid.Row="1" Background="#E8E4DC" CornerRadius="6" BorderBrush="#C0BAB0" BorderThickness="1" ClipToBounds="True"
                            PreviewMouseWheel="PreviewArea_PreviewMouseWheel">
                        <ScrollViewer x:Name="PreviewScrollViewer" HorizontalScrollBarVisibility="Auto"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FitPreviewToFrame}" Value="True">
                                            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10">

                        <!-- Плейсхолдер -->
                        <TextBlock Text="Выберите группу для предпросмотра" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Foreground="#8A8A8A" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewStudent}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- ========== ДИПЛОМ (лицевая) ========== -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedDocumentType}" Value="Диплом (лицевая)">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedDocumentType}" Value="Полный комплект (PDF)">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Viewbox HorizontalAlignment="Center" VerticalAlignment="Top"
                                     Style="{StaticResource DiplomaPreviewViewboxStyle}">
                                <Canvas x:Name="DiplomaFrontCanvas" Width="730" Height="520">
                                    <Canvas.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}"/>
                                    </Canvas.LayoutTransform>
                                    <Grid Width="730" Height="520">
                                        <Grid.Clip>
                                            <RectangleGeometry Rect="{Binding DiplomaFrontPreviewCropClipRect}"/>
                                        </Grid.Clip>
                                        <Canvas Width="730" Height="520">
                                            <Image Source="{Binding DiplomaFrontImage}" Width="730" Stretch="Uniform">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PrintDrawBackground}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="Дубликат"
                                                       FontFamily="Times New Roman"
                                                       FontSize="{Binding DiplomaFrontOverlay.DuplicateFontSize}"
                                                       FontWeight="Bold" Foreground="#000000"
                                                       Canvas.Left="{Binding DiplomaFrontOverlay.DuplicateLeft}"
                                                       Canvas.Top="{Binding DiplomaFrontOverlay.DuplicateTop}"
                                                       Width="{Binding DiplomaFrontOverlay.DuplicateWidth}"
                                                       TextAlignment="Center" Panel.ZIndex="5"
                                                       Background="Transparent" Cursor="Hand" Tag="Dup"
                                                       PreviewMouseLeftButtonDown="DiplomaOverlay_PreviewMouseLeftButtonDown"
                                                       PreviewMouseMove="DiplomaOverlay_PreviewMouseMove"
                                                       PreviewMouseLeftButtonUp="DiplomaOverlay_PreviewMouseLeftButtonUp"
                                                       ToolTip="Перетащите или задайте координаты в панели «Координаты надписей (лицевая)»">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PrintIsDuplicate}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Canvas>
                                    </Grid>
                                <Rectangle Panel.ZIndex="800" Width="6" Height="36" Cursor="SizeWE"
                                           Fill="#5500BFFF" Stroke="#993366FF" StrokeThickness="1"
                                           Canvas.Top="{Binding DiplomaFrontOverlay.DuplicateTop}"
                                           Tag="RW_Dup"
                                           PreviewMouseLeftButtonDown="DiplomaWidthGrip_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="DiplomaWidthGrip_PreviewMouseMove"
                                           PreviewMouseLeftButtonUp="DiplomaWidthGrip_PreviewMouseLeftButtonUp"
                                           ToolTip="Изменить ширину надписи «Дубликат»">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PrintIsDuplicate}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                    <Canvas.Left>
                                        <MultiBinding Converter="{StaticResource DiplomaRightGripCanvasLeftConverter}">
                                            <Binding Path="DiplomaFrontOverlay.DuplicateLeft"/>
                                            <Binding Path="DiplomaFrontOverlay.DuplicateWidth"/>
                                        </MultiBinding>
                                    </Canvas.Left>
                                </Rectangle>
                                <Line Panel.ZIndex="998" Cursor="SizeWE" Tag="GuideF1" StrokeThickness="12" Stroke="#18E91E63"
                                      Y1="0" Y2="520"
                                      X1="{Binding DiplomaFrontOverlay.CenteringGuide1X}" X2="{Binding DiplomaFrontOverlay.CenteringGuide1X}"
                                      PreviewMouseLeftButtonDown="DiplomaGuide_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="DiplomaGuide_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="DiplomaGuide_PreviewMouseLeftButtonUp"
                                      ToolTip="Направляющая 1 (лицевая)"/>
                                <Line Panel.ZIndex="999" StrokeThickness="1.5" StrokeDashArray="3 2"
                                      Stroke="#E0E91E63" SnapsToDevicePixels="True" IsHitTestVisible="False"
                                      Y1="0" Y2="520"
                                      X1="{Binding DiplomaFrontOverlay.CenteringGuide1X}" X2="{Binding DiplomaFrontOverlay.CenteringGuide1X}"/>
                                <Line Panel.ZIndex="998" Cursor="SizeWE" Tag="GuideF2" StrokeThickness="12" Stroke="#1800BCD4"
                                      Y1="0" Y2="520"
                                      X1="{Binding DiplomaFrontOverlay.CenteringGuide2X}" X2="{Binding DiplomaFrontOverlay.CenteringGuide2X}"
                                      PreviewMouseLeftButtonDown="DiplomaGuide_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="DiplomaGuide_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="DiplomaGuide_PreviewMouseLeftButtonUp"
                                      ToolTip="Направляющая 2 (лицевая)"/>
                                <Line Panel.ZIndex="999" StrokeThickness="1.5" StrokeDashArray="3 2"
                                      Stroke="#E000BCD4" SnapsToDevicePixels="True" IsHitTestVisible="False"
                                      Y1="0" Y2="520"
                                      X1="{Binding DiplomaFrontOverlay.CenteringGuide2X}" X2="{Binding DiplomaFrontOverlay.CenteringGuide2X}"/>
                                    <!-- Линейки кропа (только предпросмотр) -->
                                    <Rectangle Panel.ZIndex="2280" IsHitTestVisible="False" Fill="Transparent"
                                               Stroke="#9900796B" StrokeThickness="1" StrokeDashArray="3 2" SnapsToDevicePixels="True"
                                               Width="{Binding DiplomaFrontPreviewCropClipRect.Width}"
                                               Height="{Binding DiplomaFrontPreviewCropClipRect.Height}"
                                               Canvas.Left="{Binding DiplomaFrontPreviewCropClipRect.Left}"
                                               Canvas.Top="{Binding DiplomaFrontPreviewCropClipRect.Top}"/>
                                    <Line Panel.ZIndex="2290" Tag="DiplomaF|L" Stroke="Transparent" StrokeThickness="22" Cursor="SizeWE" SnapsToDevicePixels="True"
                                          X1="{Binding DiplomaFrontCropRulerLeftX}" X2="{Binding DiplomaFrontCropRulerLeftX}" Y1="-8" Y2="528"
                                          PreviewMouseLeftButtonDown="CropRuler_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="CropRuler_PreviewMouseMove"
                                          PreviewMouseLeftButtonUp="CropRuler_PreviewMouseLeftButtonUp"
                                          ToolTip="Кроп слева"/>
                                    <Line Panel.ZIndex="2300" Stroke="#E000796B" StrokeThickness="2" IsHitTestVisible="False" SnapsToDevicePixels="True"
                                          X1="{Binding DiplomaFrontCropRulerLeftX}" X2="{Binding DiplomaFrontCropRulerLeftX}" Y1="0" Y2="520"/>
                                    <Line Panel.ZIndex="2290" Tag="DiplomaF|R" Stroke="Transparent" StrokeThickness="22" Cursor="SizeWE" SnapsToDevicePixels="True"
                                          X1="{Binding DiplomaFrontCropRulerRightX}" X2="{Binding DiplomaFrontCropRulerRightX}" Y1="-8" Y2="528"
                                          PreviewMouseLeftButtonDown="CropRuler_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="CropRuler_PreviewMouseMove"
                                          PreviewMouseLeftButtonUp="CropRuler_PreviewMouseLeftButtonUp"
                                          ToolTip="Кроп справа"/>
                                    <Line Panel.ZIndex="2300" Stroke="#E000796B" StrokeThickness="2" IsHitTestVisible="False" SnapsToDevicePixels="True"
                                          X1="{Binding DiplomaFrontCropRulerRightX}" X2="{Binding DiplomaFrontCropRulerRightX}" Y1="0" Y2="520"/>
