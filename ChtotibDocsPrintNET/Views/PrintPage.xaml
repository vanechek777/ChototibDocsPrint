                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,0" LostFocus="CropInsetTextBox_LostFocus"
                                 Text="{Binding PreviewCropAppendix.InsetTop, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,6,0" Text="Снизу"/>
                        <TextBox Grid.Row="1" Grid.Column="3" LostFocus="CropInsetTextBox_LostFocus"
                                 Text="{Binding PreviewCropAppendix.InsetBottom, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"/>
                    </Grid>
                    <Button Content="Сброс кропа приложения" Style="{StaticResource SecondaryButton}" Padding="10,4" HorizontalAlignment="Left"
                            Command="{Binding ResetPreviewCropAppendixCommand}"/>
                    <CheckBox Margin="0,10,0,0" Content="Показывать номера страниц на приложении (лицо и оборот)"
                              IsChecked="{Binding AppendixShowPageNumbers, Mode=TwoWay}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,6" Text="Число страниц (лицевая)"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource DialogInput}"
                                 ToolTip="В фразе «Настоящее приложение содержит … страниц»"
                                 Text="{Binding AppendixFrontOverlay.PageCountText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,6" Text="Номер (лицевая, слева)"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource DialogInput}"
                                 Text="{Binding AppendixFrontOverlay.PageNum1Text, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,6" Text="Номер (лицевая, справа)"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource DialogInput}"
                                 Text="{Binding AppendixFrontOverlay.PageNum2Text, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,6" Text="Номер (оборот, слева)"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource DialogInput}"
                                 Text="{Binding AppendixBackOverlay.PageNumBackText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Номер (оборот, справа)"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource DialogInput}"
                                 Text="{Binding AppendixBackOverlay.PageNumBackRightText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                    </Grid>
                    <TextBlock FontWeight="SemiBold" FontSize="12" Margin="0,14,0,4" Text="Данные в QR (для текущего студента)"/>
                    <TextBox Style="{StaticResource DialogInput}" MinHeight="96" AcceptsReturn="True"
                             Text="{Binding PreviewQrPayload, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             ToolTip="Одна строка для QR-кода: ФИО | дата | уровень | организация | КОД … | результат. Можно редактировать."/>
                    <TextBlock FontWeight="SemiBold" FontSize="12" Margin="0,12,0,4" Text="Шаблоны подложек"/>
                    <WrapPanel>
                        <Button Content="Диплом лицо" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,6,6"
                                Command="{Binding ReplaceDiplomaFrontTemplateCommand}"/>
                        <Button Content="Диплом оборот" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,6,6"
                                Command="{Binding ReplaceDiplomaBackTemplateCommand}"/>
                        <Button Content="С отл. лицо" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,6,6"
                                Command="{Binding ReplaceDiplomaExcellentFrontTemplateCommand}"/>
                        <Button Content="С отл. оборот" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,6,6"
                                Command="{Binding ReplaceDiplomaExcellentBackTemplateCommand}"/>
                        <Button Content="Прил. лицо" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,6,6"
                                Command="{Binding ReplaceAppendixFrontTemplateCommand}"/>
                        <Button Content="Прил. оборот" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,6,6"
                                Command="{Binding ReplaceAppendixBackTemplateCommand}"/>
                    </WrapPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
