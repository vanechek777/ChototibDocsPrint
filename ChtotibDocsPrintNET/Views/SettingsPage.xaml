<UserControl x:Class="ChtotibDocsPrintNET.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Background="{DynamicResource PageBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="Настройки" Style="{StaticResource PageTitle}"/>

            <!-- ===== ОФОРМЛЕНИЕ ===== -->
            <TextBlock Text="Оформление" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,15,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Тёмная тема:" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <CheckBox IsChecked="{Binding IsDarkTheme}" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Размер шрифта таблиц:" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <ComboBox Style="{StaticResource DialogCombo}" SelectedItem="{Binding SelectedFontSize}" ItemsSource="{Binding FontSizes}"
                          Width="90"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Организация:" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox Style="{StaticResource DialogInput}" Text="{Binding OrganizationName, UpdateSourceTrigger=PropertyChanged}"
                         Width="350"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Директор:" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox Style="{StaticResource DialogInput}" Text="{Binding DirectorName, UpdateSourceTrigger=PropertyChanged}"
                         Width="350"/>
            </StackPanel>

            <!-- ===== ПОДКЛЮЧЕНИЕ К БД ===== -->
            <TextBlock Text="Подключение к базе данных" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,25,0,10"/>

            <TextBlock Text="Строка подключения к SQL Server:" FontSize="13" Margin="0,0,0,5"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox Style="{StaticResource DialogInput}" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" MinHeight="50" AcceptsReturn="False"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Style="{StaticResource ActionButton}" Content="Проверить подключение"
                        Command="{Binding TestConnectionCommand}" Padding="18,8" Margin="0,0,10,0"/>
                <Button Style="{StaticResource ActionButton}" Content="Сохранить всё"
                        Command="{Binding SaveAllCommand}" Padding="18,8"/>
            </StackPanel>

            <!-- Статус подключения -->
            <Border Margin="0,10,0,0" Padding="12,8" CornerRadius="5"
                    Visibility="{Binding HasStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#D4EDDA"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter Property="Background" Value="#F8D7DA"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#155724"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter Property="Foreground" Value="#721C24"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Инструкция -->
            <TextBlock Text="Инструкция по подключению" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,30,0,10"/>
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="18,14">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                        <Run FontWeight="Bold">1.</Run><Run Text=" Откройте SQL Server Management Studio (SSMS)"/>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0">
                        <Run FontWeight="Bold">2.</Run><Run Text=" Выполните скрипт Database\CreateDatabase.sql"/>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0">
                        <Run FontWeight="Bold">3.</Run><Run Text=" Укажите строку подключения выше и нажмите «Проверить»"/>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run FontWeight="Bold">Примеры строк:</Run>
                    </TextBlock>
                    <TextBlock FontSize="12" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="10,4,0,0" TextWrapping="Wrap"
                               Text="Server=(localdb)\MSSQLLocalDB;Database=ChtotibDocPrint;Trusted_Connection=True;TrustServerCertificate=True;"/>
                    <TextBlock FontSize="12" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="10,4,0,0" TextWrapping="Wrap"
                               Text="Server=.\SQLEXPRESS;Database=ChtotibDocPrint;Trusted_Connection=True;TrustServerCertificate=True;"/>
                    <TextBlock FontSize="12" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="10,4,0,0" TextWrapping="Wrap"
                               Text="Server=ИМЯПК;Database=ChtotibDocPrint;Trusted_Connection=True;TrustServerCertificate=True;"/>
                </StackPanel>
            </Border>

            <!-- ===== ИМПОРТ ДАННЫХ ===== -->
            <TextBlock Text="Импорт данных" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,30,0,10"/>
            <TextBlock Text="По кнопке импорта откроется окно с примером таблицы Excel и выбором файла (.xlsx, .xls, .csv). Первая строка файла — заголовок (будет пропущена)."
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <WrapPanel>
                <Button Style="{StaticResource SuccessButton}" Content="↓ Импорт специальностей" Padding="14,7"
                        Command="{Binding ImportSpecialtiesCommand}" Margin="0,0,10,8"/>
                <Button Style="{StaticResource SuccessButton}" Content="↓ Импорт предметов" Padding="14,7"
                        Command="{Binding ImportSubjectsCommand}" Margin="0,0,10,8"/>
                <Button Style="{StaticResource SuccessButton}" Content="↓ Импорт групп" Padding="14,7"
                        Command="{Binding ImportGroupsCommand}" Margin="0,0,10,8"/>
                <Button Style="{StaticResource SuccessButton}" Content="↓ Импорт студентов" Padding="14,7"
                        Command="{Binding ImportStudentsCommand}" Margin="0,0,10,8"/>
            </WrapPanel>

            <Button Style="{StaticResource ActionButton}" Content="Мастер подключения к 1С…" Padding="16,9" Margin="0,14,0,0"
                    HorizontalAlignment="Left" Command="{Binding OpenOneCWizardCommand}"/>
            <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                       Text="OData или выгрузка в Excel/CSV. Пошаговая инструкция — в окне мастера."/>

            <TextBlock Text="Обслуживание базы" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,28,0,10"/>
            <Button Style="{StaticResource SecondaryButton}" Content="Очистить сиротские записи" Padding="14,7"
                    HorizontalAlignment="Left" Command="{Binding CleanDatabaseCommand}"/>
            <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                       Text="Удаляет оценки/дипломы/историю печати без привязки к существующему студенту или предмету."/>

            <StackPanel Height="30"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
